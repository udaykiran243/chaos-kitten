# Copy this file to `.env` and fill in the values:
#
#   cp .env.example .env
#
# Notes:
# - Never commit your real `.env` file.
# - Chaos Kitten also expands `${VAR}` placeholders inside `chaos-kitten.yaml`.

# REQUIRED: Anthropic Claude API key for LLM-powered attack planning and analysis
# Example: sk-ant-api03-...
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTIONAL: OpenAI API key as alternative LLM provider for attack planning
# Example: sk-proj-...
OPENAI_API_KEY=your_openai_api_key_here

# OPTIONAL: Ollama server base URL for running with local LLM models
# Example: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# OPTIONAL: Logging level for application output (DEBUG, INFO, WARNING, ERROR)
# Example: DEBUG
CHAOS_KITTEN_LOG_LEVEL=INFO

# OPTIONAL: Custom configuration file path to override default chaos-kitten.yaml
# Example: /path/to/custom/config.yaml
CHAOS_KITTEN_CONFIG=chaos-kitten.yaml

# OPTIONAL: Custom toys registry URL to override default registry location
# Example: https://raw.githubusercontent.com/custom-registry/main/toys/registry.json
CHAOS_KITTEN_REGISTRY_URL=https://raw.githubusercontent.com/mdhaarishussain/chaos-kitten/main/toys/registry.json

# OPTIONAL: Target API auth token (referenced by chaos-kitten.yaml as `${API_TOKEN}`)
# Example: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
API_TOKEN=your_target_api_token_here
